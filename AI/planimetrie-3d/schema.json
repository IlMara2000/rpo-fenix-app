{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fenix 3D Floor Plan",
  "type": "object",
  "required": ["title", "style", "width", "depth", "wallHeight", "wallThickness", "rooms"],
  "properties": {
    "title": { "type": "string" },
    "style": { "type": "string" },
    "width": { "type": "number", "minimum": 4, "maximum": 40 },
    "depth": { "type": "number", "minimum": 4, "maximum": 40 },
    "wallHeight": { "type": "number", "minimum": 2.2, "maximum": 4 },
    "wallThickness": { "type": "number", "minimum": 0.08, "maximum": 0.4 },
    "rooms": {
      "type": "array",
      "minItems": 1,
      "maxItems": 14,
      "items": {
        "type": "object",
        "required": ["id", "name", "type", "x", "z", "width", "depth", "height", "color", "furniture"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "x": { "type": "number" },
          "z": { "type": "number" },
          "width": { "type": "number", "minimum": 1.4, "maximum": 16 },
          "depth": { "type": "number", "minimum": 1.4, "maximum": 16 },
          "height": { "type": "number", "minimum": 0.04, "maximum": 0.2 },
          "color": { "type": "string" },
          "furniture": {
            "type": "array",
            "maxItems": 12,
            "items": {
              "type": "object",
              "required": ["id", "type", "x", "z", "width", "depth", "height", "color"],
              "properties": {
                "id": { "type": "string" },
                "type": { "type": "string" },
                "x": { "type": "number" },
                "z": { "type": "number" },
                "width": { "type": "number", "minimum": 0.2, "maximum": 5 },
                "depth": { "type": "number", "minimum": 0.2, "maximum": 5 },
                "height": { "type": "number", "minimum": 0.05, "maximum": 2.4 },
                "color": { "type": "string" },
                "rotation": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": { "type": "string" }
  }
}
